# HDF4 round-trip test: write data, read it back, verify channel info.
# Exits non-zero (via assert -E) if any property is wrong.
dip_simulate 4 2 32 100 eg_source
write_hdf test_hdf4_roundtrip.hdf
null_sink
-
read_hdf test_hdf4_roundtrip.hdf
assert -E nr_of_channels == 37
assert -E nr_of_points == 132
assert -E sfreq == 4
assert -E channelname == A1
assert -E channelname == A37
assert -E nr_of_triggers == 0
null_sink
